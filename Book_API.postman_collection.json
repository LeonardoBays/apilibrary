{
  "info": {
    "_postman_id": "book-collection",
    "name": "Book API",
    "description": "Collection for Book Management API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Book",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"1984\",\n  \"description\": \"A dystopian social science fiction novel and cautionary tale written by English writer George Orwell. The novel is set in Airstrip One, a province of the superstate Oceania in a world of perpetual war, omnipresent government surveillance, and public mind control.\",\n  \"publisherId\": 1,\n  \"authorId\": 1\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/books",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "books"
          ]
        },
        "description": "Create a new book with title, description, publisher ID, and author ID"
      },
      "response": []
    },
    {
      "name": "Get All Books",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/books",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "books"
          ]
        },
        "description": "Retrieve all books from the library"
      },
      "response": []
    },
    {
      "name": "Get Book by ID",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/books/1",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "books",
            "1"
          ]
        },
        "description": "Retrieve a specific book by its ID"
      },
      "response": []
    },
    {
      "name": "Get Books by Publisher",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/books/publisher/1",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "books",
            "publisher",
            "1"
          ]
        },
        "description": "Retrieve all books from a specific publisher by publisher ID"
      },
      "response": []
    },
    {
      "name": "Search Books",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/books/search?keyword=Orwell&sortOrder=asc",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "books",
            "search"
          ],
          "query": [
            {
              "key": "keyword",
              "value": "Orwell",
              "description": "Search term - searches across title, description, author name, and publisher name"
            },
            {
              "key": "sortOrder",
              "value": "asc",
              "description": "Sorting order: 'asc' for ascending or 'desc' for descending (default: asc)"
            }
          ]
        },
        "description": "Search books by keyword (title, description, author name, or publisher name) with sorting options"
      },
      "response": []
    },
    {
      "name": "Update Book",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"1984 - Revised Edition\",\n  \"description\": \"A dystopian social science fiction novel and cautionary tale written by English writer George Orwell. The novel is set in Airstrip One, a province of the superstate Oceania in a world of perpetual war, omnipresent government surveillance, and public mind control. This is the revised edition with additional commentary.\",\n  \"publisherId\": 1,\n  \"authorId\": 1\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/books/1",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "books",
            "1"
          ]
        },
        "description": "Update an existing book's information"
      },
      "response": []
    },
    {
      "name": "Delete Book",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/books/1",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "books",
            "1"
          ]
        },
        "description": "Permanently delete a book from the library"
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "",
      "type": "string"
    }
  ]
}
