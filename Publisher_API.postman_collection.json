{
  "info": {
    "_postman_id": "publisher-collection",
    "name": "Publisher API",
    "description": "Collection for Publisher Management API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Publisher",
      "request": {
        "method": "POST",
        "header": [          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Penguin Books\",\n  \"description\": \"Leading publisher of classic and contemporary literature for readers worldwide\",\n  \"website\": \"https://www.penguin.co.uk\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/publishers",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "publishers"
          ]
        },
        "description": "Create a new publisher with name, description, and website"
      },
      "response": []
    },
    {
      "name": "Get All Publishers",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/publishers",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "publishers"
          ]
        },
        "description": "Retrieve all publishers (including inactive)"
      },
      "response": []
    },
    {
      "name": "Get Active Publishers",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/publishers/active",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "publishers",
            "active"
          ]
        },
        "description": "Retrieve only active publishers"
      },
      "response": []
    },
    {
      "name": "Get Publisher by ID",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/publishers/1",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "publishers",
            "1"
          ]
        },
        "description": "Retrieve a specific publisher by their ID"
      },
      "response": []
    },
    {
      "name": "Update Publisher",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Penguin Books Updated\",\n  \"description\": \"One of the world's leading publishers with offices in multiple countries\",\n  \"website\": \"https://www.penguin.com\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/publishers/1",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "publishers",
            "1"
          ]
        },
        "description": "Update an existing publisher's information"
      },
      "response": []
    },
    {
      "name": "Deactivate Publisher",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/publishers/1/deactivate",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "publishers",
            "1",
            "deactivate"
          ]
        },
        "description": "Deactivate a publisher (soft delete)"
      },
      "response": []
    },
    {
      "name": "Reactivate Publisher",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/publishers/1/reactivate",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "publishers",
            "1",
            "reactivate"
          ]
        },
        "description": "Reactivate a previously deactivated publisher"
      },
      "response": []
    },
    {
      "name": "Delete Publisher",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/publishers/1",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "publishers",
            "1"
          ]
        },
        "description": "Permanently delete a publisher from the database"
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "",
      "type": "string"
    }
  ]
}
